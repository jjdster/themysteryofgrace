{
  "entities": {
    "Comment": {
      "title": "Comment",
      "description": "A user-submitted comment on the website.",
      "type": "object",
      "properties": {
        "text": {
          "type": "string",
          "description": "The content of the comment."
        },
        "authorName": {
          "type": "string",
          "description": "The name of the person who wrote the comment."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "When the comment was created."
        },
        "status": {
          "type": "string",
          "enum": ["approved", "flagged"],
          "description": "The moderation status of the comment."
        },
        "attitude": {
          "type": "string",
          "description": "The AI's assessment of the comment's attitude."
        }
      },
      "required": ["text", "createdAt", "status"]
    },
    "StudyLog": {
      "title": "StudyLog",
      "description": "A log of a single study interaction.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "userEmail": { "type": "string" },
        "lessonTitle": { "type": "string" },
        "type": { "type": "string", "enum": ["question", "quiz", "chat"] },
        "data": { "type": "object" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["lessonTitle", "type", "data", "timestamp"]
    },
    "StudySession": {
      "title": "StudySession",
      "description": "A collection of interactions in a single study session.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "userEmail": { "type": "string" },
        "lessonTitle": { "type": "string" },
        "startTime": { "type": "string", "format": "date-time" },
        "lastUpdateTime": { "type": "string", "format": "date-time" },
        "interactions": {
          "type": "array",
          "items": { "type": "object" }
        }
      },
      "required": ["lessonTitle", "startTime", "lastUpdateTime", "interactions"]
    },
    "UserProgress": {
      "title": "UserProgress",
      "description": "Tracks a user's progress through various studies.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "completedLessons": {
          "type": "array",
          "items": { "type": "string" }
        },
        "quizScores": {
          "type": "object",
          "description": "Map of lessonTitle to highest score."
        },
        "bookmarks": {
          "type": "array",
          "items": { "type": "string" }
        },
        "lastAccessed": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "completedLessons", "quizScores"]
    }
  },
  "firestore": {
    "comments": {
      "schema": "Comment",
      "description": "Publicly visible approved comments with optional categories."
    },
    "flagged_comments": {
      "schema": "Comment",
      "description": "Comments that failed moderation."
    },
    "study_logs": {
      "schema": "StudyLog",
      "description": "Logs of study interactions."
    },
    "study_sessions": {
      "schema": "StudySession",
      "description": "Grouped study sessions."
    },
    "user_progress": {
      "schema": "UserProgress",
      "description": "Individual user study progress."
    }
  }
}
