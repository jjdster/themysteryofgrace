{
  "entities": {
    "ContactMessage": {
      "title": "Contact Message",
      "description": "A message sent from the contact form.",
      "type": "object",
      "properties": {
        "fullName": {
          "type": "string",
          "description": "The full name of the sender."
        },
        "email": {
          "type": "string",
          "format": "email",
          "description": "The email address of the sender."
        },
        "subject": {
          "type": "string",
          "description": "The subject of the message."
        },
        "message": {
          "type": "string",
          "description": "The content of the message."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "When the message was sent."
        }
      },
      "required": ["fullName", "email", "subject", "message", "createdAt"]
    }
  },
  "firestore": {
    "/contact_messages/{messageId}": {
      "schema": "ContactMessage",
      "description": "Collection of contact form submissions."
    }
  }
}
