rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() && 
             request.auth.token.email == "jjdster@gmail.com" && 
             request.auth.token.email_verified == true;
    }

    // Publicly readable approved comments
    match /comments/{commentId} {
      allow read: if true; // Publicly readable
      allow create: if true; // Anyone can create
      allow update, delete: if isAdmin();
    }

    // Flagged comments (only for admin/backend)
    match /flagged_comments/{commentId} {
      allow read: if isAdmin();
      allow create: if true; // Anyone can create
      allow update, delete: if isAdmin();
    }

    // Study logs (anyone can write, only admin can read)
    match /study_logs/{logId} {
      allow read: if isAdmin();
      allow create: if true; // Anyone can log their activity
    }

    // Study sessions (anyone can write, only admin can read)
    match /study_sessions/{sessionId} {
      allow read: if isAdmin();
      allow create, update: if true; // Anyone can update their session
    }

    // User progress (only the owner can read/write)
    match /user_progress/{userId} {
      allow read, write: if isAuthenticated() && request.auth.uid == userId;
    }

    // Test connection path
    match /test/connection {
      allow read: if true;
    }
  }
}
